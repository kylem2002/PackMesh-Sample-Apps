@page "/"
@using System.Diagnostics
@using System.Text.Json
@using Microsoft.JSInterop
@inject PackMeshClient Client
@inject IJSRuntime JS

<h1>PackMesh Blazor API Playground</h1>
<p class="muted">Run guided scenario workflows with live status, validation, and response tabs.</p>

@* Developer-first orientation: explain the happy path before users run any API calls. *@
<section class="quickstart" aria-labelledby="quickstart-title">
  <h2 id="quickstart-title">Quick start (30 seconds)</h2>
  <ol>
    <li>Add an API key (use a test key where possible).</li>
    <li>Keep the <strong>Create Scenario</strong> template selected, then click <strong>Run Full Workflow</strong>.</li>
    <li>Inspect the response summary first, then use the <strong>Response</strong> and <strong>Logs</strong> tabs for full details.</li>
  </ol>
  <p class="muted compact">Tip: If a step fails, use <strong>Retry Last Failed Step</strong> with the same payload after you fix the issue.</p>
</section>

<div class="workspace-grid">
  <section class="panel">
    @* Left panel: collect credentials + payload + workflow controls. *@
    <h2>Configuration</h2>

    <label for="apiKey">API key</label>
    <div class="row wrap">
      <input id="apiKey"
             type="@(ShowApiKey ? "text" : "password")"
             class="api-key-input"
             @bind="ApiKey"
             @bind:event="oninput"
             @bind:after="OnApiKeyChanged"
             placeholder="pmk_live_..." />
      <button class="secondary" @onclick="ToggleApiKeyVisibility">@(ShowApiKey ? "Hide" : "Show")</button>
      <button class="secondary" @onclick="PasteApiKeyAsync">Paste</button>
      <button class="secondary" @onclick="ClearKey">Clear</button>
    </div>
    <div class="row wrap compact-row">
      <label class="inline-check">
        <input type="checkbox" @bind="RememberApiKeyForSession" @bind:after="OnRememberApiKeyChangedAsync" /> Remember in this browser session only
      </label>
      <span class="api-state @(IsApiKeyMissing ? "api-state-error" : "api-state-ok")" role="status" aria-live="polite">
        API Key: @(IsApiKeyMissing ? "Not connected" : "Connected ✓")
      </span>
    </div>
    @if (ShowApiKeyValidation)
    {
      <p class="validation-message">API key is required before making requests.</p>
    }

    <div class="editor-toolbar">
      <label for="templateSelect">Example JSON</label>
      <select id="templateSelect" @bind="SelectedTemplate" @bind:after="ApplyTemplate">
        <option value="scenario">Create Scenario</option>
        <option value="run">Run Scenario</option>
        <option value="status">Poll Status</option>
        <option value="edge">Edge Case (mixed constraints)</option>
        <option value="invalid">Invalid Example (validation demo)</option>
        <option value="customEquipment">Create Custom Equipment</option>
      </select>
      <button class="secondary" @onclick="FormatRequestJson">Format JSON</button>
    </div>

    <label for="payloadEditor">Request JSON</label>
    <textarea id="payloadEditor" @bind="RequestJson" rows="18" class="payload-editor"></textarea>
    @if (!string.IsNullOrWhiteSpace(JsonValidationError))
    {
      <p class="validation-message">@JsonValidationError</p>
    }

    <div class="steps">
      <p class="steps-title">Workflow</p>
      <ol>
        <li class="@(string.IsNullOrWhiteSpace(ScenarioId) ? string.Empty : "done")">Step 1 — Create Scenario</li>
        <li class="@(string.IsNullOrWhiteSpace(RunId) ? string.Empty : "done")">Step 2 — Run Scenario</li>
        <li class="@(Status == "complete" ? "done" : string.Empty)">Step 3 — Poll Status</li>
      </ol>
    </div>

    <div class="row wrap action-row">
      <button class="primary primary-blue" @onclick="CreateScenarioAsync" disabled="@(IsBusy || IsApiKeyMissing)">Create Scenario</button>
      <button class="primary primary-green" @onclick="RunScenarioAsync" disabled="@(IsBusy || IsApiKeyMissing || string.IsNullOrWhiteSpace(ScenarioId))">Run Scenario</button>
      <button class="primary primary-amber" @onclick="PollStatusAsync" disabled="@(IsBusy || IsApiKeyMissing || string.IsNullOrWhiteSpace(RunId))">Poll Status</button>
      <button class="primary primary-purple" @onclick="RunFullWorkflowAsync" disabled="@(IsBusy || IsApiKeyMissing)">Run Full Workflow</button>
      <button class="secondary" @onclick="GetEquipmentCatalogAsync" disabled="@(IsBusy || IsApiKeyMissing)">Get Equipment Catalog</button>
      <button class="secondary" @onclick="CreateCustomEquipmentAsync" disabled="@(IsBusy || IsApiKeyMissing)">Create Custom Equipment</button>
      <button class="secondary" @onclick="CancelAutoPolling" disabled="@(!IsWorkflowRunning)">Cancel</button>
      <label class="inline-check">
        <input type="checkbox" @bind="AutoPollEnabled" /> Auto-poll until completion
      </label>
      @if (IsBusy)
      {
        <span class="loading" role="status" aria-live="polite">Loading…</span>
      }
    </div>
  </section>

  <section class="panel">
    @* Right panel: status, output tabs, and troubleshooting utilities. *@
    <h2>Actions & Results</h2>

    <div class="status-meta" role="status" aria-live="polite">
      <div class="status-row">
        <span class="result">ScenarioId: @DisplayOrDash(ScenarioId)</span>
        <span class="result">RunId: @DisplayOrDash(RunId)</span>
        <span class="badge @StatusClass">@StatusLabel</span>
        @if (LastDurationMs > 0)
        {
          <span class="result">@LastDurationMs ms</span>
        }
      </div>
      @if (StatusTimeline.Count > 0)
      {
        <ul class="timeline">
          @foreach (var entry in StatusTimeline.Take(6))
          {
            <li>@entry</li>
          }
        </ul>
      }
    </div>

    @if (ResponseSummary is not null)
    {
      <div class="summary-grid">
        <span>Total rows: <strong>@ResponseSummary.TotalRows</strong></span>
        <span>Unique bins: <strong>@ResponseSummary.UniqueBins</strong></span>
        <span>Total weight: <strong>@ResponseSummary.TotalWeight.ToString("0.##")</strong></span>
        <span>Layers: <strong>@ResponseSummary.MaxLayer</strong></span>
      </div>
    }

    <div class="tabs" role="tablist" aria-label="Result views">
      <button id="tab-response" role="tab" aria-selected="@(ActiveTab == "response")" aria-controls="panel-response" class="@(ActiveTab == "response" ? "tab active" : "tab")" @onclick='() => ActiveTab = "response"'>Response</button>
      <button id="tab-logs" role="tab" aria-selected="@(ActiveTab == "logs")" aria-controls="panel-logs" class="@(ActiveTab == "logs" ? "tab active" : "tab")" @onclick='() => ActiveTab = "logs"'>Logs</button>
      <button id="tab-raw" role="tab" aria-selected="@(ActiveTab == "raw")" aria-controls="panel-raw" class="@(ActiveTab == "raw" ? "tab active" : "tab")" @onclick='() => ActiveTab = "raw"'>Request Payload JSON</button>
    </div>

    <div class="row wrap compact-row">
      <input class="search-input" placeholder="Search in current tab..." @bind="ResultSearch" @bind:event="oninput" />
      <button class="secondary" @onclick="CopyActiveTabAsync">@CopyButtonLabel</button>
      <button class="secondary" @onclick="DownloadActiveTabAsync">@DownloadButtonLabel</button>
      <button class="secondary" @onclick="LoadRecentRunsAsync">Refresh Recent Runs</button>
      <button class="secondary" @onclick="ClearResultsPanel">Clear Results</button>
      <button class="secondary" @onclick="JumpToError">Jump to "error"</button>
      <button class="secondary" @onclick="RetryLastFailedStepAsync" disabled="@string.IsNullOrWhiteSpace(LastFailedAction)">Retry Last Failed Step</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
      <div class="error-banner" role="alert" aria-live="assertive">@Error</div>
    }

    <div id="panel-response" role="tabpanel" aria-labelledby="tab-response" hidden="@(ActiveTab != "response")">
      <pre class="results">@DisplayWithSearch(ResultsJson, "No response yet.")</pre>
    </div>
    <div id="panel-logs" role="tabpanel" aria-labelledby="tab-logs" hidden="@(ActiveTab != "logs")">
      <pre class="results">@DisplayWithSearch(LogOutput, "No logs yet.")</pre>
    </div>
    <div id="panel-raw" role="tabpanel" aria-labelledby="tab-raw" hidden="@(ActiveTab != "raw")">
      <pre class="results">@DisplayWithSearch(RequestJson, "No request JSON.")</pre>
    </div>

    <h3>Recent Runs (local)</h3>
    <pre class="results">@DisplayWithSearch(RecentRunsJson, "No recent runs yet.")</pre>
  </section>
</div>

@* Small JS helper for downloading JSON without adding extra dependencies. *@
<script>
  window.packmeshDownloadText = (filename, text) => {
    const blob = new Blob([text], { type: "application/json;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  };
</script>

<style>
